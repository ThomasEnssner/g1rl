includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - app/
        - bootstrap/app.php
        - config/
        - database/
        - routes/

    level: 7

    ignoreErrors:
        # False positive: the trait is used by the Livewire single-file
        # component resources/views/pages/settings/⚡profile.blade.php,
        # which PHPStan cannot parse (PHP + Blade in one file).
        -
            identifier: trait.unused
            path: app/Concerns/ProfileValidationRules.php
